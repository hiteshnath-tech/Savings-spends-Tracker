  position: relative;
}

.ai-bubble-header {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 8px;
  font-size: 11px;
  font-weight: 700;
  color: var(--neon3);
  text-transform: uppercase;
  letter-spacing: 0.8px;
}

.ai-dot {
  width: 8px;
  height: 8px;
  background: var(--neon3);
  border-radius: 50%;
  animation: blink 2s infinite;
}

@keyframes blink { 0%,100%{opacity:1} 50%{opacity:0.3} }

.ai-bubble p { color: var(--text); }

/* DAILY BAR CHART (custom) */
.bars { display: flex; align-items: flex-end; gap: 5px; height: 80px; }
.bcol { flex: 1; display: flex; flex-direction: column; align-items: center; gap: 4px; height: 100%; justify-content: flex-end; }
.bfill { width: 100%; border-radius: 4px 4px 0 0; transition: height 0.5s ease; min-height: 3px; }
.bfill.g { background: rgba(0,245,160,0.25); }
.bfill.g.hi { background: var(--neon); box-shadow: 0 0 8px rgba(0,245,160,0.4); }
.bfill.r { background: rgba(255,77,109,0.25); }
.bfill.r.hi { background: var(--red); box-shadow: 0 0 8px rgba(255,77,109,0.4); }
.bfill.z { background: rgba(255,255,255,0.05); }
.blbl { font-family: 'DM Mono', monospace; font-size: 8px; color: var(--text3); }
.blbl.today { color: var(--neon); font-weight: 700; }

/* NET BALANCE CARD */
.net-card {
  background: var(--glass);
  border: 1px solid var(--glass-border);
  border-radius: var(--radius-sm);
  padding: 14px 20px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12px;
  backdrop-filter: blur(16px);
}

.net-label-col { display: flex; flex-direction: column; gap: 2px; }
.net-label { font-size: 10px; font-weight: 700; color: var(--text3); text-transform: uppercase; letter-spacing: 0.9px; }
.net-sub { font-size: 11px; color: var(--text3); }
.net-amount { font-size: 24px; font-weight: 800; letter-spacing: -0.5px; font-family: 'DM Mono', monospace; }
.net-amount.pos { color: var(--neon); text-shadow: 0 0 20px rgba(0,245,160,0.3); }
.net-amount.neg { color: var(--red); text-shadow: 0 0 20px rgba(255,77,109,0.3); }

/* WEEKLY COMPARISON */
.week-compare {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 12px 14px;
  background: var(--glass);
  border: 1px solid var(--glass-border);
  border-radius: var(--radius-sm);
  margin-bottom: 12px;
  font-size: 13px;
  backdrop-filter: blur(12px);
}

.week-icon { font-size: 20px; }
.week-text { flex: 1; color: var(--text2); }
.week-text strong { color: var(--amber); }
.week-text.good strong { color: var(--neon); }

/* SCROLL BAR */
::-webkit-scrollbar { width: 4px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.1); border-radius: 2px; }


/* ═══════════════════════════════════════
   AUTH SCREENS — FULL SYSTEM
═══════════════════════════════════════ */
.auth-box {
  position: relative;
  width: 100%;
  max-width: 420px;
  background: var(--glass);
  border: 1px solid var(--glass-border);
  border-radius: 28px;
  padding: 36px 32px;
  backdrop-filter: blur(24px);
  -webkit-backdrop-filter: blur(24px);
  box-shadow: 0 32px 80px rgba(0,0,0,0.6), 0 0 0 1px rgba(255,255,255,0.04);
  animation: loginPop 0.35s cubic-bezier(0.34,1.4,0.64,1);
}

@keyframes loginPop {
  from { opacity:0; transform:scale(0.92) translateY(16px); }
  to   { opacity:1; transform:scale(1) translateY(0); }
}

.auth-back {
  background: none; border: none; color: var(--text3); cursor: pointer;
  font-family: 'Syne',sans-serif; font-size: 13px; font-weight: 600;
  padding: 0 0 16px 0; display: flex; align-items: center; gap: 4px;
  transition: color 0.2s;
}
.auth-back:hover { color: var(--neon); }

.auth-section-label {
  font-size: 10px; font-weight: 700; color: var(--text3);
  text-transform: uppercase; letter-spacing: 1px; margin-bottom: 4px;
}

.auth-divider {
  display: flex; align-items: center; gap: 10px;
  font-size: 11px; color: var(--text3);
  margin: 18px 0;
}
.auth-divider::before, .auth-divider::after {
  content:''; flex:1; height:1px; background: var(--glass-border);
}

/* Password input with eye toggle */
.pw-wrap {
  position: relative;
}
.pw-wrap input {
  width: 100%; padding-right: 42px;
}
.pw-eye {
  position: absolute; right: 10px; top: 50%; transform: translateY(-50%);
  background: none; border: none; cursor: pointer; font-size: 16px;
  opacity: 0.5; transition: opacity 0.2s; padding: 4px;
}
.pw-eye:hover { opacity: 1; }

/* Password strength bar */
.pw-strength {
  height: 3px; border-radius: 2px; margin-top: 6px;
  transition: all 0.3s; background: transparent;
  font-size: 10px; color: var(--text3); padding-top: 3px;
}

/* User avatar big */
.user-avatar-big {
  width: 64px; height: 64px; border-radius: 50%;
  background: linear-gradient(135deg, var(--neon), var(--neon3));
  display: flex; align-items: center; justify-content: center;
  font-size: 28px; font-weight: 800; color: #001a0e;
  margin: 0 auto 14px;
  box-shadow: 0 0 30px rgba(0,245,160,0.25);
}

/* PIN pad */
.pin-dots {
  display: flex; gap: 12px; justify-content: center; margin: 20px 0 16px;
}
.pin-dot {
  width: 14px; height: 14px; border-radius: 50%;
  border: 2px solid var(--text3);
  transition: all 0.2s;
}
.pin-dot.filled {
  background: var(--neon);
  border-color: var(--neon);
  box-shadow: 0 0 10px rgba(0,245,160,0.5);
}

.pin-pad {
  display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px;
  max-width: 260px; margin: 0 auto;
}
.pin-key {
  background: var(--glass); border: 1px solid var(--glass-border);
  border-radius: 14px; padding: 16px;
  font-family: 'Syne',sans-serif; font-size: 20px; font-weight: 700;
  color: var(--text); cursor: pointer;
  transition: all 0.15s; text-align: center;
  backdrop-filter: blur(12px);
}
.pin-key:hover { background: rgba(0,245,160,0.1); border-color: var(--neon); color: var(--neon); }
.pin-key:active { transform: scale(0.92); }
.pin-key.wide { grid-column: span 2; font-size: 13px; font-weight: 600; }
.pin-key.del { font-size: 18px; }

/* Lockout banner */
.lockout-banner {
  background: rgba(255,77,109,0.1); border: 1px solid rgba(255,77,109,0.3);
  border-radius: 10px; padding: 10px 14px;
  font-size: 12px; color: var(--red); margin-bottom: 12px;
  text-align: center; font-weight: 600;
}

/* Google button */
.btn-google {
  width: 100%; padding: 12px; border-radius: 12px;
  background: var(--glass); border: 1px solid var(--glass-border);
  font-family: 'Syne',sans-serif; font-size: 14px; font-weight: 700;
  color: var(--text); cursor: pointer;
  display: flex; align-items: center; justify-content: center; gap: 10px;
  transition: all 0.2s; backdrop-filter: blur(12px);
}
.btn-google:hover {
  background: rgba(255,255,255,0.08); border-color: rgba(255,255,255,0.2);
  transform: translateY(-1px);
}

/* Settings user row */
.settings-user-row {
  display: flex; align-items: center; gap: 14px;
  background: rgba(0,245,160,0.06); border: 1px solid rgba(0,245,160,0.15);
  border-radius: 14px; padding: 14px 16px;
}
.settings-user-info { flex:1; }
.settings-user-name { font-size: 15px; font-weight: 800; color: var(--text); }
.settings-user-since { font-size: 11px; color: var(--text3); margin-top:2px; font-family:'DM Mono',monospace; }

/* User chips */
.user-chips { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 16px; }
.user-chip {
  display: flex; align-items: center; gap: 6px;
  background: var(--glass); border: 1px solid var(--glass-border);
  border-radius: 20px; padding: 7px 14px;
  font-size: 13px; font-weight: 600; color: var(--text2);
  cursor: pointer; transition: all 0.2s;
}
.user-chip:hover { border-color: var(--neon); color: var(--neon); background: rgba(0,245,160,0.08); }
.user-chip-avatar {
  width: 22px; height: 22px; border-radius: 50%;
  background: linear-gradient(135deg, var(--neon), var(--neon3));
  display: flex; align-items: center; justify-content: center;
  font-size: 11px; font-weight: 800; color: #001a0e; flex-shrink: 0;
}

/* login-logo, login-title, login-sub, login-error (kept from before) */
.login-logo {
  width: 52px; height: 52px;
  background: linear-gradient(135deg, var(--neon), var(--neon2));
  border-radius: 14px; display: flex; align-items: center; justify-content: center;
  font-size: 24px; margin: 0 auto 16px;
  box-shadow: 0 0 28px rgba(0,245,160,0.3);
}
.login-title {
  text-align: center; font-size: 22px; font-weight: 800;
  letter-spacing: -0.5px; margin-bottom: 4px;
}
.login-title span { color: var(--neon); }
.login-sub {
  text-align: center; font-size: 12px; color: var(--text3); margin-bottom: 24px;
}
.login-error {
  color: var(--red); font-size: 12px; text-align: center;
  margin-top: 8px; min-height: 16px; font-weight: 600;
}

/* User badge in topbar */
.user-badge {
  display: flex; align-items: center; gap: 7px;
  background: var(--glass); border: 1px solid var(--glass-border);
  border-radius: 20px; padding: 4px 10px 4px 4px;
  cursor: pointer; transition: all 0.2s;
  font-size: 12px; font-weight: 700; color: var(--text2);
}
.user-badge:hover { border-color: var(--neon); color: var(--neon); }
.user-avatar {
  width: 26px; height: 26px; border-radius: 50%;
  background: linear-gradient(135deg, var(--neon), var(--neon3));
  display: flex; align-items: center; justify-content: center;
  font-size: 12px; font-weight: 800; color: #001a0e; flex-shrink: 0;
}

</style>
