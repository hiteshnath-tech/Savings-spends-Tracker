let recognition=null;
function startVoice() {
  const SR=window.SpeechRecognition||window.webkitSpeechRecognition;
  if(!SR){showToast("Voice not supported");return;}
  const btn=document.getElementById("voiceBtn");
  if(recognition){recognition.stop();recognition=null;btn.classList.remove("listening");btn.textContent="🎤";return;}
  recognition=new SR();recognition.lang="en-IN";recognition.interimResults=false;
  btn.classList.add("listening");btn.textContent="🔴";
  recognition.onresult=e=>{
    const t=e.results[0][0].transcript.toLowerCase();
    document.getElementById("spendNote").value=t;
    const nm=t.match(/(\d+)/);if(nm)document.getElementById("spendAmt").value=nm[1];
    const cm={food:["food","lunch","dinner","breakfast","restaurant","swiggy","zomato"],travel:["travel","bus","auto","uber","ola","cab","train"],shopping:["shopping","buy","bought","amazon","flipkart"],bills:["bill","electricity","recharge","wifi","rent"],entertainment:["movie","game","netflix","fun"],health:["medicine","doctor","hospital","gym"]};
    for(const[cat,words]of Object.entries(cm)){if(words.some(w=>t.includes(w))){document.getElementById("spendCat").value=cat.charAt(0).toUpperCase()+cat.slice(1);break;}}
    showToast("🎤 "+t.slice(0,28)+"...");btn.classList.remove("listening");btn.textContent="🎤";recognition=null;
  };
  recognition.onerror=recognition.onend=()=>{btn.classList.remove("listening");btn.textContent="🎤";recognition=null;};
  recognition.start();
}

// ── RENDER (async for encrypted data) ──
async function renderAsync() {
  const [savings,spends,goal,budget]= await Promise.all([loadSavings(),loadSpends(),loadGoal(),loadBudget()]);
  const t=today();
  const totalSaved=savings.reduce((s,e)=>s+e.amount,0);
  const totalSpent=spends.reduce((s,e)=>s+e.amount,0);
  const net=totalSaved-totalSpent;
  const active=savings.filter(e=>e.amount>0).length;
  const maxSave=Math.max(...savings.map(e=>e.amount),1);
  const bestSave=savings.length?Math.max(...savings.map(e=>e.amount)):0;
  const avgSave=savings.length?Math.round(totalSaved/savings.length):0;
  const bigSpend=spends.length?Math.max(...spends.map(e=>e.amount)):0;
  const avgSpend=spends.length?Math.round(totalSpent/spends.length):0;

  document.getElementById("topDate").textContent=new Date().toLocaleDateString("en-IN",{weekday:"short",day:"2-digit",month:"short"});
  document.getElementById("totalSaved").textContent=totalSaved.toLocaleString("en-IN");
  document.getElementById("totalSpent").textContent=totalSpent.toLocaleString("en-IN");
  document.getElementById("saveSub").textContent=`${active} of ${savings.length} days active`;
  document.getElementById("spendSub").textContent=`${spends.length} transaction${spends.length!==1?'s':''}`;
  const netEl=document.getElementById("netAmt");
  netEl.textContent=(net>=0?"+":"-")+" ₹"+Math.abs(net).toLocaleString("en-IN");
  netEl.className="net-amount "+(net>=0?"pos":"neg");
  const pct=goal>0?Math.min(Math.round(totalSaved/goal*100),100):0;
  document.getElementById("ringCircle").style.strokeDashoffset=251-(pct/100*251);
  document.getElementById("ringPct").firstChild.textContent=pct+"%";
  document.getElementById("goalSub").textContent=`₹${totalSaved.toLocaleString("en-IN")} saved / ₹${(goal||0).toLocaleString("en-IN")} goal`;
  document.getElementById("sBest").textContent=bestSave.toLocaleString("en-IN");
  document.getElementById("sAvg").textContent=avgSave.toLocaleString("en-IN");
  document.getElementById("sBig").textContent=bigSpend.toLocaleString("en-IN");
  document.getElementById("sAvgS").textContent=avgSpend.toLocaleString("en-IN");
  showAlerts(totalSpent,budget);
  showWeeklyComparison(spends);
  updateAIInsight(savings,spends);

  const catTotals={};
  spends.forEach(s=>{catTotals[s.cat]=(catTotals[s.cat]||0)+s.amount;});
  Object.keys(CAT_COLORS).forEach(cat=>{const el=document.getElementById("cat-"+cat);if(el)el.textContent=catTotals[cat]?"₹"+catTotals[cat].toLocaleString("en-IN"):"₹0";});

  const sc=savings.slice(-12);
  document.getElementById("saveChart").innerHTML=sc.map(e=>{const p=(e.amount/maxSave)*100,isT=e.date===t;return`<div class="bcol"><div class="bfill ${e.amount===0?'z':'g'} ${p>60?'hi':''}" style="height:${Math.max(p,e.amount===0?3:6)}%"></div><div class="blbl ${isT?'today':''}">${dayShort(e.date)}</div></div>`;}).join('');

  const spendByDate={};
  spends.forEach(s=>{spendByDate[s.date]=(spendByDate[s.date]||0)+s.amount;});
  const spendDates=Object.keys(spendByDate).sort().slice(-12);
  const maxSpD=Math.max(...Object.values(spendByDate),1);
  document.getElementById("spendChart").innerHTML=spendDates.length?spendDates.map(d=>{const amt=spendByDate[d],pct=(amt/maxSpD)*100;return`<div class="bcol"><div class="bfill r ${pct>60?'hi':''}" style="height:${Math.max(pct,6)}%"></div><div class="blbl ${d===t?'today':''}">${dayShort(d)}</div></div>`;}).join(''):`<div style="width:100%;text-align:center;color:var(--text3);font-size:12px;padding:20px 0">No spending data yet</div>`;

  const catMax=Math.max(...Object.values(catTotals),1);
  document.getElementById("catRows").innerHTML=Object.keys(catTotals).length?Object.entries(catTotals).sort((a,b)=>b[1]-a[1]).map(([cat,amt])=>{const p=Math.round((amt/totalSpent)*100);return`<div class="cat-row"><div class="cat-row-dot" style="background:${CAT_COLORS[cat]||'#6b7280'}"></div><div class="cat-row-name">${cat}</div><div class="cat-row-bar"><div class="cat-row-fill" style="width:${(amt/catMax)*100}%;background:${CAT_COLORS[cat]||'#6b7280'}"></div></div><div class="cat-row-pct">${p}%</div><div class="cat-row-total">₹${amt.toLocaleString("en-IN")}</div></div>`;}).join(''):`<div class="empty"><span class="empty-icon">🏷️</span><p>No spends logged yet</p></div>`;

  const sTbody=document.getElementById("saveTbody");
  sTbody.innerHTML=savings.length?[...savings].reverse().map(e=>{const isT=e.date===t,p=(e.amount/maxSave)*100;return`<tr class="${isT?'today-row':''}"><td class="td-date" style="${isT?'color:var(--neon);font-weight:700':''}">${fmtDate(e.date)}</td><td style="font-size:12px;color:var(--text2)">${dayFull(e.date).slice(0,3)}</td><td><div class="mini-bar"><div class="mini-fill" style="width:${p}%;background:var(--neon)"></div></div></td><td class="td-amt ${e.amount===0?'z':'g'}">${e.amount===0?'—':'₹'+e.amount.toLocaleString('en-IN')}</td><td><button class="del-btn" onclick="delSaving('${e.date}')">×</button></td></tr>`;}).join(''):`<tr><td colspan="5"><div class="empty"><span class="empty-icon">📭</span><p>No savings yet</p></div></td></tr>`;

  const spTbody=document.getElementById("spendTbody");
  if(!spends.length){spTbody.innerHTML=`<tr><td colspan="5"><div class="empty"><span class="empty-icon">🧾</span><p>No expenses yet</p></div></td></tr>`;}
  else{spTbody.innerHTML=[...spends].reverse().map((e,i)=>{const color=CAT_COLORS[e.cat]||"#6b7280",realIdx=spends.length-1-i;return`<tr class="${e.date===t?'today-row':''}"><td class="td-date">${fmtDate(e.date)}</td><td><span class="badge" style="background:${color}">${e.cat}</span></td><td style="font-size:12px;color:var(--text2);max-width:130px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${e.note||'—'}</td><td class="td-amt r">₹${e.amount.toLocaleString('en-IN')}</td><td><button class="del-btn" onclick="delSpend(${realIdx})">×</button></td></tr>`;}).join('');}
}

// ── ADD / DELETE ──
async function addSaving() {
  const date=document.getElementById("saveDate").value;
  const amt=parseFloat(document.getElementById("saveAmt").value);
  if(!date||isNaN(amt)||amt<0) return;
  let data=await loadSavings();
  const idx=data.findIndex(e=>e.date===date);
  if(idx>=0)data[idx].amount=amt;
  else{data.push({date,amount:amt});data.sort((a,b)=>a.date.localeCompare(b.date));}
  await saveSavings(data);
  document.getElementById("saveAmt").value="";
  flash("saveBtn","+ Add Saving");
  await renderAsync();
}

async function addSpend() {
  const date=document.getElementById("spendDate").value;
  const amt=parseFloat(document.getElementById("spendAmt").value);
  const cat=document.getElementById("spendCat").value;
  const note=document.getElementById("spendNote").value.trim();
  if(!date||isNaN(amt)||amt<=0) return;
  let data=await loadSpends();
  data.push({date,amount:amt,cat,note});
  data.sort((a,b)=>a.date.localeCompare(b.date));
  await saveSpends(data);
  document.getElementById("spendAmt").value="";
  document.getElementById("spendNote").value="";
  flash("spendBtn","+ Add Expense");
  await renderAsync();
}

async function delSaving(date){const d=await loadSavings();await saveSavings(d.filter(e=>e.date!==date));await renderAsync();}
async function delSpend(idx){const d=await loadSpends();d.splice(idx,1);await saveSpends(d);await renderAsync();}

function flash(id,label){
  const btn=document.getElementById(id);
  btn.textContent="✓ Saved!";btn.classList.add("ok");
  setTimeout(()=>{btn.textContent=label;btn.classList.remove("ok");},1400);
}

// ── EXPORT ──
async function exportCSV() {
  const [savings,spends]=await Promise.all([loadSavings(),loadSpends()]);
  let csv="Type,Date,Amount,Category,Note\n";
  savings.forEach(e=>{csv+=`Saving,${e.date},${e.amount},,\n`;});
  spends.forEach(e=>{csv+=`Expense,${e.date},${e.amount},${e.cat},"${e.note||''}"\n`;});
  dl("finance-data.csv",csv,"text/csv");showToast("✅ CSV exported!");
}
async function exportJSON() {
  const [savings,spends,goal,budget]=await Promise.all([loadSavings(),loadSpends(),loadGoal(),loadBudget()]);
  dl("finance-data.json",JSON.stringify({savings,spends,goal,budget,exported:new Date().toISOString()},null,2),"application/json");
  showToast("✅ JSON exported!");
}
function dl(name,content,type){const a=document.createElement("a");a.href=URL.createObjectURL(new Blob([content],{type}));a.download=name;a.click();}

async function printSummary() {
  const [savings,spends]=await Promise.all([loadSavings(),loadSpends()]);
  const tS=savings.reduce((s,e)=>s+e.amount,0),tP=spends.reduce((s,e)=>s+e.amount,0),net=tS-tP;
  const w=window.open("","_blank");
  w.document.write(`<html><head><title>Finance Summary</title><style>body{font-family:sans-serif;padding:30px;color:#0f1923}h1{color:#059669}table{width:100%;border-collapse:collapse;margin-top:10px}th,td{border:1px solid #eee;padding:8px;text-align:left}th{background:#f0fdf4}.pos{color:#059669}.neg{color:#e11d48}</style></head><body><h1>FinanceTrack · ${CURRENT_DISPLAY}</h1><p>${new Date().toLocaleDateString("en-IN",{weekday:"long",year:"numeric",month:"long",day:"numeric"})}</p><table><tr><th>Total Saved</th><td class="pos">₹${tS.toLocaleString("en-IN")}</td></tr><tr><th>Total Spent</th><td class="neg">₹${tP.toLocaleString("en-IN")}</td></tr><tr><th>Net Balance</th><td class="${net>=0?'pos':'neg'}">₹${Math.abs(net).toLocaleString("en-IN")}</td></tr></table><h3>Savings</h3><table><tr><th>Date</th><th>Amount</th></tr>${[...savings].reverse().slice(0,10).map(e=>`<tr><td>${e.date}</td><td>₹${e.amount}</td></tr>`).join('')}</table><h3>Expenses</h3><table><tr><th>Date</th><th>Category</th><th>Note</th><th>Amount</th></tr>${[...spends].reverse().slice(0,10).map(e=>`<tr><td>${e.date}</td><td>${e.cat}</td><td>${e.note||'-'}</td><td>₹${e.amount}</td></tr>`).join('')}</table></body></html>`);
  w.document.close();w.print();
}

