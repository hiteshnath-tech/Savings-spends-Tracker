<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>FinanceTrack · ₹</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet"/>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<style>
:root {
  --bg: #0a0d14;
  --bg2: #0f1320;
  --card: rgba(255,255,255,0.04);
  --card-border: rgba(255,255,255,0.08);
  --glass: rgba(255,255,255,0.06);
  --glass-border: rgba(255,255,255,0.12);
  --text: #f0f4ff;
  --text2: #8892a4;
  --text3: #4a5568;
  --neon: #00f5a0;
  --neon2: #00d4ff;
  --neon3: #a78bfa;
  --red: #ff4d6d;
  --amber: #fbbf24;
  --green: #00f5a0;
  --radius: 20px;
  --radius-sm: 12px;
  --shadow: 0 8px 32px rgba(0,0,0,0.4);
  --glow: 0 0 20px rgba(0,245,160,0.2);
}

[data-theme="light"] {
  --bg: #f0f2f8;
  --bg2: #e8ebf4;
  --card: rgba(255,255,255,0.9);
  --card-border: rgba(0,0,0,0.08);
  --glass: rgba(255,255,255,0.7);
  --glass-border: rgba(0,0,0,0.1);
  --text: #0f1923;
  --text2: #4a5568;
  --text3: #8a97a8;
  --neon: #059669;
  --neon2: #0284c7;
  --neon3: #7c3aed;
  --red: #e11d48;
  --amber: #d97706;
  --green: #059669;
  --shadow: 0 8px 32px rgba(0,0,0,0.1);
  --glow: 0 0 20px rgba(5,150,105,0.15);
}

*{box-sizing:border-box;margin:0;padding:0}

body {
  background: var(--bg);
  color: var(--text);
  font-family: 'Syne', sans-serif;
  min-height: 100vh;
  overflow-x: hidden;
}

/* MESH BACKGROUND */
body::before {
  content:'';
  position:fixed;
  inset:0;
  background:
    radial-gradient(ellipse 60% 50% at 20% 20%, rgba(0,245,160,0.06) 0%, transparent 60%),
    radial-gradient(ellipse 40% 40% at 80% 10%, rgba(0,212,255,0.05) 0%, transparent 50%),
    radial-gradient(ellipse 50% 60% at 70% 80%, rgba(167,139,250,0.05) 0%, transparent 60%);
  pointer-events:none;
  z-index:0;
}

/* TOPBAR */
.topbar {
  position: sticky;
  top: 0;
  z-index: 200;
  background: rgba(10,13,20,0.85);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-bottom: 1px solid var(--card-border);
  padding: 0 20px;
  height: 60px;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

[data-theme="light"] .topbar {
  background: rgba(240,242,248,0.85);
}

.brand {
  display: flex;
  align-items: center;
  gap: 10px;
}

.brand-icon {
  width: 36px;
  height: 36px;
  background: linear-gradient(135deg, var(--neon), var(--neon2));
  border-radius: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18px;
  box-shadow: var(--glow);
}

.brand-name {
  font-size: 18px;
  font-weight: 800;
  letter-spacing: -0.5px;
}

.brand-name span { color: var(--neon); }

.topbar-right {
  display: flex;
  align-items: center;
  gap: 10px;
}

.top-date {
  font-family: 'DM Mono', monospace;
  font-size: 11px;
  color: var(--text3);
  background: var(--card);
  border: 1px solid var(--card-border);
  padding: 5px 12px;
  border-radius: 20px;
}

/* THEME TOGGLE */
.toggle-wrap {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: 12px;
  color: var(--text2);
}

.toggle {
  width: 40px;
  height: 22px;
  background: var(--card);
  border: 1px solid var(--card-border);
  border-radius: 11px;
  position: relative;
  cursor: pointer;
  transition: background 0.3s;
}

.toggle.on { background: linear-gradient(90deg, var(--neon), var(--neon2)); border-color: transparent; }

.toggle-knob {
  position: absolute;
  top: 3px;
  left: 3px;
  width: 14px;
  height: 14px;
  background: #fff;
  border-radius: 50%;
  transition: transform 0.3s;
  box-shadow: 0 1px 4px rgba(0,0,0,0.3);
}

.toggle.on .toggle-knob { transform: translateX(18px); }

/* WRAP */
.wrap {
  max-width: 680px;
  margin: 0 auto;
  padding: 24px 16px 100px;
  position: relative;
  z-index: 1;
}

/* GLASS CARD */
.card {
  background: var(--glass);
  border: 1px solid var(--glass-border);
  border-radius: var(--radius);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  box-shadow: var(--shadow);
  margin-bottom: 14px;
  overflow: hidden;
}

.card-pad { padding: 20px; }

.card-title {
  font-size: 11px;
  font-weight: 700;
  color: var(--text3);
  text-transform: uppercase;
  letter-spacing: 1.2px;
  margin-bottom: 16px;
  display: flex;
  align-items: center;
  gap: 6px;
}

.card-title::before {
  content: '';
  display: inline-block;
  width: 3px;
  height: 14px;
  background: linear-gradient(var(--neon), var(--neon2));
  border-radius: 2px;
}

/* HERO GRID */
.hero-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12px;
  margin-bottom: 12px;
}

.hero-card {
  background: var(--glass);
  border: 1px solid var(--glass-border);
  border-radius: var(--radius);
  padding: 20px;
  backdrop-filter: blur(16px);
  position: relative;
  overflow: hidden;
  transition: transform 0.2s, box-shadow 0.2s;
}

.hero-card:hover { transform: translateY(-2px); box-shadow: var(--shadow); }

.hero-card::after {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 2px;
}

.hero-card.green::after { background: linear-gradient(90deg, var(--neon), transparent); }
.hero-card.red::after { background: linear-gradient(90deg, var(--red), transparent); }
.hero-card.blue::after { background: linear-gradient(90deg, var(--neon2), transparent); }
.hero-card.purple::after { background: linear-gradient(90deg, var(--neon3), transparent); }

.hero-icon {
  font-size: 22px;
  margin-bottom: 10px;
  display: block;
}

.hero-label {
  font-size: 10px;
  font-weight: 600;
  color: var(--text3);
  text-transform: uppercase;
  letter-spacing: 0.9px;
  margin-bottom: 4px;
}

.hero-amount {
  font-size: 26px;
  font-weight: 800;
  letter-spacing: -1px;
  line-height: 1;
}

.hero-card.green .hero-amount { color: var(--neon); }
.hero-card.red .hero-amount { color: var(--red); }
.hero-card.blue .hero-amount { color: var(--neon2); }
.hero-card.purple .hero-amount { color: var(--neon3); }

.hero-sub {
  font-family: 'DM Mono', monospace;
  font-size: 10px;
  color: var(--text3);
  margin-top: 4px;
}

/* SAVINGS GOAL RING */
.goal-card {
  background: var(--glass);
  border: 1px solid var(--glass-border);
  border-radius: var(--radius);
  padding: 20px;
  backdrop-filter: blur(16px);
  display: flex;
  align-items: center;
  gap: 20px;
  margin-bottom: 12px;
}

.ring-wrap {
  position: relative;
  width: 90px;
  height: 90px;
  flex-shrink: 0;
}

.ring-svg { width: 90px; height: 90px; transform: rotate(-90deg); }

.ring-bg { fill: none; stroke: rgba(255,255,255,0.06); stroke-width: 8; }
.ring-fill {
  fill: none;
  stroke: url(#ringGrad);
  stroke-width: 8;
  stroke-linecap: round;
  stroke-dasharray: 251;
  stroke-dashoffset: 251;
  transition: stroke-dashoffset 1.2s cubic-bezier(0.4,0,0.2,1);
}

.ring-pct {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  font-weight: 800;
  font-size: 18px;
  color: var(--neon);
  line-height: 1;
}

.ring-pct small {
  font-size: 9px;
  color: var(--text3);
  font-weight: 500;
  margin-top: 2px;
}

.goal-info { flex: 1; }
.goal-title { font-size: 13px; font-weight: 700; color: var(--text); margin-bottom: 4px; }
.goal-sub { font-size: 11px; color: var(--text2); margin-bottom: 10px; font-family: 'DM Mono', monospace; }

.goal-input-row {
  display: flex;
  gap: 6px;
  align-items: center;
}

.goal-input {
  background: rgba(255,255,255,0.06);
  border: 1px solid var(--glass-border);
  border-radius: 8px;
  padding: 7px 10px;
  font-family: 'Syne', sans-serif;
  font-size: 13px;
  font-weight: 600;
  color: var(--text);
  width: 110px;
  outline: none;
}

.goal-input:focus { border-color: var(--neon); }

.goal-btn {
  background: linear-gradient(135deg, var(--neon), var(--neon2));
  border: none;
  border-radius: 8px;
  padding: 7px 14px;
  font-family: 'Syne', sans-serif;
  font-size: 12px;
  font-weight: 700;
  color: #0a0d14;
  cursor: pointer;
  transition: opacity 0.2s;
}

.goal-btn:hover { opacity: 0.85; }

/* ALERT BANNER */
.alert {
  background: rgba(251,191,36,0.1);
  border: 1px solid rgba(251,191,36,0.3);
  border-radius: var(--radius-sm);
  padding: 12px 16px;
  margin-bottom: 12px;
  display: flex;
  align-items: center;
  gap: 10px;
  font-size: 13px;
  color: var(--amber);
  font-weight: 600;
  animation: slideDown 0.3s ease;
}

.alert.red-alert {
  background: rgba(255,77,109,0.1);
  border-color: rgba(255,77,109,0.3);
  color: var(--red);
}

.alert span { font-size: 18px; }
.alert-close { margin-left: auto; cursor: pointer; opacity: 0.6; font-size: 16px; }
.alert-close:hover { opacity: 1; }

/* INSIGHT CARD */
.insight {
  background: linear-gradient(135deg, rgba(0,245,160,0.08), rgba(0,212,255,0.05));
  border: 1px solid rgba(0,245,160,0.2);
  border-radius: var(--radius-sm);
  padding: 14px 16px;
  margin-bottom: 12px;
  font-size: 13px;
  color: var(--text2);
  display: flex;
  align-items: center;
  gap: 10px;
}

.insight-icon { font-size: 20px; flex-shrink: 0; }
.insight-text { line-height: 1.5; }
.insight-text strong { color: var(--text); }

/* STATS ROW */
.stats {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 10px;
  margin-bottom: 14px;
}

@media (max-width: 480px) { .stats { grid-template-columns: repeat(2, 1fr); } }

.stat {
  background: var(--glass);
  border: 1px solid var(--glass-border);
  border-radius: var(--radius-sm);
  padding: 14px 10px;
  text-align: center;
  backdrop-filter: blur(16px);
  transition: transform 0.2s;
}

.stat:hover { transform: translateY(-2px); }
.stat-label { font-size: 9px; font-weight: 700; color: var(--text3); text-transform: uppercase; letter-spacing: 0.9px; margin-bottom: 6px; }
.stat-value { font-size: 17px; font-weight: 800; letter-spacing: -0.5px; }
.stat-value.g { color: var(--neon); }
.stat-value.r { color: var(--red); }
.stat-cur { font-size: 10px; }

/* TABS */
.tabs {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 0;
  background: var(--glass);
  border: 1px solid var(--glass-border);
  border-radius: var(--radius-sm);
  padding: 4px;
  margin-bottom: 18px;
  backdrop-filter: blur(16px);
}

.tab {
  padding: 10px 6px;
  border: none;
  background: transparent;
  border-radius: 9px;
  font-family: 'Syne', sans-serif;
  font-size: 12px;
  font-weight: 700;
  color: var(--text2);
  cursor: pointer;
  transition: all 0.22s;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 5px;
  letter-spacing: 0.2px;
}

.tab:hover { background: rgba(255,255,255,0.05); color: var(--text); }
.tab.active-save { background: linear-gradient(135deg, rgba(0,245,160,0.2), rgba(0,212,255,0.15)); color: var(--neon); border: 1px solid rgba(0,245,160,0.25); }
.tab.active-spend { background: linear-gradient(135deg, rgba(255,77,109,0.2), rgba(255,100,80,0.15)); color: var(--red); border: 1px solid rgba(255,77,109,0.25); }
.tab.active-analytics { background: linear-gradient(135deg, rgba(167,139,250,0.2), rgba(0,212,255,0.15)); color: var(--neon3); border: 1px solid rgba(167,139,250,0.25); }

/* SECTIONS */
.sec { display: none; animation: fadeIn 0.3s ease; }
.sec.active { display: block; }

@keyframes fadeIn { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }
@keyframes slideDown { from { opacity: 0; transform: translateY(-6px); } to { opacity: 1; transform: translateY(0); } }

/* CHARTS */
.chart-wrap { height: 200px; position: relative; }
.chart-wrap canvas { border-radius: 12px; }

.chart-duo {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12px;
  margin-bottom: 14px;
}

@media (max-width: 480px) { .chart-duo { grid-template-columns: 1fr; } }

.chart-mini { height: 180px; position: relative; }

/* CATEGORY CARDS */
.cat-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 8px;
  margin-bottom: 14px;
}

@media (max-width: 480px) { .cat-grid { grid-template-columns: repeat(2, 1fr); } }

.cat-card {
  background: var(--glass);
  border: 1px solid var(--glass-border);
  border-radius: var(--radius-sm);
  padding: 14px 10px;
  text-align: center;
  cursor: pointer;
  transition: all 0.22s;
  position: relative;
  overflow: hidden;
  backdrop-filter: blur(12px);
}

.cat-card:hover { transform: translateY(-3px); }
.cat-card.selected { border-color: currentColor; }

.cat-card::before {
  content: '';
  position: absolute;
  inset: 0;
  opacity: 0;
  transition: opacity 0.22s;
}

.cat-card:hover::before { opacity: 0.06; }

.cat-emoji { font-size: 22px; display: block; margin-bottom: 6px; }
.cat-name-label { font-size: 10px; font-weight: 700; color: var(--text2); letter-spacing: 0.3px; }
.cat-amount { font-family: 'DM Mono', monospace; font-size: 11px; color: var(--text3); margin-top: 3px; }

/* FORM */
.form-grid { display: grid; gap: 12px; margin-bottom: 14px; }
.form-grid.two { grid-template-columns: 1fr 1fr; }
.form-grid.three { grid-template-columns: 1fr 1fr 1fr; }

@media (max-width: 480px) { .form-grid.two, .form-grid.three { grid-template-columns: 1fr; } }

.field label {
  display: block;
  font-size: 10px;
  font-weight: 700;
  color: var(--text3);
  text-transform: uppercase;
  letter-spacing: 0.9px;
  margin-bottom: 7px;
}

.field input, .field select {
  width: 100%;
  background: rgba(255,255,255,0.05);
  border: 1.5px solid var(--glass-border);
  border-radius: 10px;
  padding: 11px 14px;
  font-family: 'Syne', sans-serif;
  font-size: 14px;
  font-weight: 500;
  color: var(--text);
  outline: none;
  transition: border-color 0.2s, box-shadow 0.2s, background 0.2s;
  appearance: none;
}

[data-theme="light"] .field input,
[data-theme="light"] .field select {
  background: rgba(255,255,255,0.8);
}

.field input:focus, .field select:focus {
  border-color: var(--neon);
  background: rgba(0,245,160,0.04);
  box-shadow: 0 0 0 3px rgba(0,245,160,0.1);
}

.field input::placeholder { color: var(--text3); font-weight: 400; }
.field input::-webkit-calendar-picker-indicator { filter: invert(1) opacity(0.3); cursor: pointer; }

[data-theme="light"] .field input::-webkit-calendar-picker-indicator { filter: opacity(0.4); }

.field select option { background: #0f1320; color: var(--text); }
[data-theme="light"] .field select option { background: #fff; color: #0f1923; }

/* BTN ROW */
.btn-row { display: flex; gap: 10px; }

.btn {
  flex: 1;
  padding: 13px;
  border: none;
  border-radius: 12px;
  font-family: 'Syne', sans-serif;
  font-size: 14px;
  font-weight: 700;
  cursor: pointer;
  transition: all 0.2s;
  position: relative;
  overflow: hidden;
  letter-spacing: 0.2px;
}

.btn::after {
  content: '';
  position: absolute;
  inset: 0;
  background: radial-gradient(circle at center, rgba(255,255,255,0.3) 0%, transparent 60%);
  opacity: 0;
  transition: opacity 0.3s;
  transform: scale(0);
}

.btn:active::after { opacity: 1; transform: scale(1); transition: 0s; }

.btn-green {
  background: linear-gradient(135deg, #00f5a0, #00b37a);
  color: #001a0e;
  box-shadow: 0 4px 20px rgba(0,245,160,0.25);
}

.btn-green:hover { box-shadow: 0 6px 24px rgba(0,245,160,0.4); transform: translateY(-1px); }

.btn-red {
  background: linear-gradient(135deg, #ff4d6d, #c9184a);
  color: #fff;
  box-shadow: 0 4px 20px rgba(255,77,109,0.25);
}

.btn-red:hover { box-shadow: 0 6px 24px rgba(255,77,109,0.4); transform: translateY(-1px); }

.btn-ghost {
  background: var(--glass);
  border: 1px solid var(--glass-border);
  color: var(--text2);
  backdrop-filter: blur(16px);
}

.btn-ghost:hover { color: var(--text); background: rgba(255,255,255,0.08); }

.btn.ok { background: linear-gradient(135deg, #00f5a0, #00b37a) !important; color: #001a0e !important; }
.btn:active { transform: scale(0.98); }

/* VOICE BTN */
.voice-btn {
  background: var(--glass);
  border: 1.5px solid var(--glass-border);
  border-radius: 10px;
  padding: 11px 14px;
  font-size: 18px;
  cursor: pointer;
  transition: all 0.2s;
  flex-shrink: 0;
}

.voice-btn:hover { border-color: var(--neon); background: rgba(0,245,160,0.08); }
.voice-btn.listening { border-color: var(--red); background: rgba(255,77,109,0.1); animation: pulse 1s infinite; }

@keyframes pulse { 0%,100%{box-shadow:0 0 0 0 rgba(255,77,109,0.4)} 50%{box-shadow:0 0 0 8px rgba(255,77,109,0)} }

/* TABLE */
.tbl-wrap { overflow-x: auto; }

.tbl {
  width: 100%;
  border-collapse: collapse;
  font-size: 13px;
}

.tbl th {
  font-size: 9px;
  font-weight: 700;
  color: var(--text3);
  text-transform: uppercase;
  letter-spacing: 0.9px;
  padding: 12px 14px;
  text-align: left;
  border-bottom: 1px solid var(--glass-border);
  white-space: nowrap;
}

.tbl td {
  padding: 12px 14px;
  border-bottom: 1px solid rgba(255,255,255,0.04);
  vertical-align: middle;
}

.tbl tr:last-child td { border-bottom: none; }
.tbl tr:hover td { background: rgba(255,255,255,0.02); }
.tbl tr.today-row td { background: rgba(0,245,160,0.04); }

.td-date { font-family: 'DM Mono', monospace; font-size: 11px; white-space: nowrap; }
.td-amt { font-family: 'DM Mono', monospace; font-size: 13px; font-weight: 600; text-align: right; white-space: nowrap; }
.td-amt.g { color: var(--neon); }
.td-amt.r { color: var(--red); }
.td-amt.z { color: var(--text3); }

.badge {
  display: inline-block;
  font-size: 10px;
  font-weight: 700;
  padding: 3px 9px;
  border-radius: 20px;
  letter-spacing: 0.3px;
  color: #fff;
}

.del-btn {
  background: none;
  border: none;
  color: var(--text3);
  cursor: pointer;
  font-size: 15px;
  width: 26px;
  height: 26px;
  border-radius: 6px;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.15s;
}

.del-btn:hover { color: var(--red); background: rgba(255,77,109,0.1); }

/* MINI PROGRESS BAR */
.mini-bar { width: 60px; height: 4px; background: rgba(255,255,255,0.06); border-radius: 2px; overflow: hidden; display: inline-block; vertical-align: middle; }
.mini-fill { height: 100%; border-radius: 2px; }

/* EMPTY STATE */
.empty {
  text-align: center;
  padding: 40px 20px;
  color: var(--text3);
}

.empty-icon { font-size: 32px; display: block; margin-bottom: 8px; }
.empty p { font-size: 13px; }

/* CAT BREAKDOWN ROWS */
.cat-rows { display: flex; flex-direction: column; gap: 12px; }

.cat-row {
  display: flex;
  align-items: center;
  gap: 10px;
}

.cat-row-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }
.cat-row-name { font-size: 13px; font-weight: 600; color: var(--text); width: 95px; flex-shrink: 0; }
.cat-row-bar { flex: 1; height: 6px; background: rgba(255,255,255,0.06); border-radius: 3px; overflow: hidden; }
.cat-row-fill { height: 100%; border-radius: 3px; transition: width 0.6s ease; }
.cat-row-pct { font-family: 'DM Mono', monospace; font-size: 10px; color: var(--text3); width: 28px; text-align: right; flex-shrink: 0; }
