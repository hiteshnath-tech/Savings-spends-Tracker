<script>
// ═══════════════════════════════════════════════════
//  FINANCETRACK · FULL AUTH SYSTEM
//  SHA-256 password hashing · PIN · Session tokens
//  AES-GCM encrypted data · Lockout · Change/Delete
// ═══════════════════════════════════════════════════

// ── CRYPTO HELPERS ──
async function sha256(str) {
  const buf = await crypto.subtle.digest('SHA-256', new TextEncoder().encode(str));
  return Array.from(new Uint8Array(buf)).map(b=>b.toString(16).padStart(2,'0')).join('');
}

// AES-GCM encryption (key derived from password hash)
async function deriveKey(passwordHash) {
  const raw = await crypto.subtle.importKey('raw',
    new TextEncoder().encode(passwordHash.slice(0,32).padEnd(32,'0')),
    'AES-GCM', false, ['encrypt','decrypt']);
  return raw;
}

async function encryptData(data, passwordHash) {
  try {
    const key = await deriveKey(passwordHash);
    const iv  = crypto.getRandomValues(new Uint8Array(12));
    const enc = await crypto.subtle.encrypt({name:'AES-GCM',iv},
      key, new TextEncoder().encode(JSON.stringify(data)));
    return btoa(String.fromCharCode(...iv) + String.fromCharCode(...new Uint8Array(enc)));
  } catch(e) { return JSON.stringify(data); }
}

async function decryptData(ciphertext, passwordHash) {
  try {
    const key  = await deriveKey(passwordHash);
    const raw  = Uint8Array.from(atob(ciphertext), c=>c.charCodeAt(0));
    const iv   = raw.slice(0,12);
    const data = raw.slice(12);
    const dec  = await crypto.subtle.decrypt({name:'AES-GCM',iv}, key, data);
    return JSON.parse(new TextDecoder().decode(dec));
  } catch(e) { try { return JSON.parse(ciphertext); } catch(e2){ return null; } }
}

// ── SESSION ──
let CURRENT_USER = null;       // username key
let CURRENT_DISPLAY = null;    // display name
let SESSION_PW_HASH = null;    // for encrypt/decrypt
let ACTIVE_STEP_USER = null;   // user being logged in

const SESSION_KEY = 'ft_session';
const USERS_KEY   = 'ft_users_v2';

function generateToken() {
  return Array.from(crypto.getRandomValues(new Uint8Array(24)))
    .map(b=>b.toString(16).padStart(2,'0')).join('');
}

// ── USER STORE ──
function getAllUsers() {
  try { return JSON.parse(localStorage.getItem(USERS_KEY)||'[]'); } catch(e){return [];}
}
function saveAllUsers(users) { localStorage.setItem(USERS_KEY, JSON.stringify(users)); }
function getUserByKey(key) { return getAllUsers().find(u=>u.key===key)||null; }

function userDataKey(field) { return `ft_data_${CURRENT_USER}_${field}`; }

// ── LOCKOUT ──
function getLockout(key) {
  try { return JSON.parse(localStorage.getItem('ft_lock_'+key)||'{"fails":0,"until":0}'); } catch(e){return {fails:0,until:0};}
}
function setLockout(key, obj) { localStorage.setItem('ft_lock_'+key, JSON.stringify(obj)); }
function recordFail(key) {
  const l = getLockout(key);
  l.fails++;
  if(l.fails >= 5) l.until = Date.now() + 5*60*1000; // 5 min lockout
  setLockout(key, l);
  return l;
}
function clearLockout(key) { localStorage.removeItem('ft_lock_'+key); }
function isLockedOut(key) {
  const l = getLockout(key);
  if(l.until > Date.now()) return Math.ceil((l.until-Date.now())/1000);
  if(l.until && l.until < Date.now()) { clearLockout(key); }
  return 0;
}

// ── DATA LAYER (encrypted) ──
async function loadUserData(field, fallback=[]) {
  const raw = localStorage.getItem(userDataKey(field));
  if(!raw) return fallback;
  return (await decryptData(raw, SESSION_PW_HASH)) || fallback;
}
async function saveUserData(field, data) {
  const enc = await encryptData(data, SESSION_PW_HASH);
  localStorage.setItem(userDataKey(field), enc);
}

// Wrappers used by rest of app
async function loadSavings() { return loadUserData('savings', []); }
async function loadSpends()  { return loadUserData('spends',  []); }
async function saveSavings(d){ return saveUserData('savings', d); }
async function saveSpends(d) { return saveUserData('spends',  d); }
async function loadGoal()    { return (await loadUserData('goal',   [0]))[0]||0; }
async function saveGoal(v)   { return saveUserData('goal',   [v]); }
async function loadBudget()  { return (await loadUserData('budget', [0]))[0]||0; }
async function saveBudget(v) { return saveUserData('budget', [v]); }

// ── PIN SYSTEM ──
let pinBuffer = '';
const PIN_LEN_MIN = 4;

function buildPinPad(onFill) {
  const pad = document.getElementById('pinPad');
  const keys = ['1','2','3','4','5','6','7','8','9','','0','⌫'];
  pad.innerHTML = keys.map((k,i) => {
    if(k==='') return '<div></div>';
    const cls = k==='⌫' ? 'pin-key del' : 'pin-key';
    return `<button class="${cls}" onclick="pinPress('${k}')">${k}</button>`;
  }).join('');
  pinBuffer = '';
  updatePinDots();
}

function pinPress(k) {
  if(k==='⌫') { pinBuffer = pinBuffer.slice(0,-1); }
  else if(pinBuffer.length < 6) { pinBuffer += k; }
  updatePinDots();
  if(pinBuffer.length >= PIN_LEN_MIN) {
    setTimeout(()=>submitPin(), 200);
  }
}

function updatePinDots() {
  const dots = document.querySelectorAll('#pinDots .pin-dot');
  dots.forEach((d,i)=>d.classList.toggle('filled', i < pinBuffer.length));
}

async function submitPin() {
  const user = ACTIVE_STEP_USER;
  if(!user) return;
  const secs = isLockedOut(user.key+'_pin');
  if(secs) { showErr('pinError',`Locked out. Try in ${secs}s`); pinBuffer=''; updatePinDots(); return; }
  const hash = await sha256(pinBuffer + user.key);
  if(hash === user.pinHash) {
    clearLockout(user.key+'_pin');
    SESSION_PW_HASH = user.pwHash; // use stored pw hash for decryption
    startSession(user);
  } else {
    const l = recordFail(user.key+'_pin');
    pinBuffer = ''; updatePinDots();
    const left = 5 - l.fails;
    showErr('pinError', l.until > Date.now() ? 'Too many attempts. Locked 5 min.' : `Wrong PIN. ${left} attempt${left!==1?'s':''} left.`);
  }
}

// ── REGISTRATION ──
async function registerUser() {
  const name = document.getElementById('regUsername').value.trim();
  const pw   = document.getElementById('regPassword').value;
  const pin  = document.getElementById('regPin').value;

  if(!name || name.length < 2) return showErr('regError','Username must be at least 2 characters');
  if(!pw || pw.length < 6)     return showErr('regError','Password must be at least 6 characters');
  if(pin && (pin.length < 4 || !/^\d+$/.test(pin))) return showErr('regError','PIN must be 4–6 digits');

  const key = name.toLowerCase().replace(/[^a-z0-9]/g,'_');
  const users = getAllUsers();
  if(users.find(u=>u.key===key)) return showErr('regError','Username already taken. Choose another or sign in.');

  const pwHash  = await sha256(pw + key + 'ft_salt_2026');
  const pinHash = pin ? await sha256(pin + key) : null;
  const token   = generateToken();

  const user = {
    key, displayName: name,
    pwHash, pinHash,
    createdAt: new Date().toISOString(),
    token
  };
  users.push(user);
  saveAllUsers(users);
  showErr('regError','');
  SESSION_PW_HASH = pwHash;
  ACTIVE_STEP_USER = user;
  startSession(user);
}

// ── LOGIN ──
async function doLogin() {
  const user = ACTIVE_STEP_USER;
  if(!user) return;

  const secs = isLockedOut(user.key);
  if(secs) {
    document.getElementById('lockoutBanner').style.display='block';
    document.getElementById('lockoutBanner').textContent=`Account locked. Try again in ${secs} seconds.`;
    return;
  }

  const pw = document.getElementById('loginPassword').value;
  if(!pw) return showErr('loginError','Enter your password');
  const hash = await sha256(pw + user.key + 'ft_salt_2026');
  if(hash === user.pwHash) {
    clearLockout(user.key);
    SESSION_PW_HASH = user.pwHash;
    startSession(user);
  } else {
    const l = recordFail(user.key);
    const left = 5 - l.fails;
    if(l.until > Date.now()) {
      document.getElementById('lockoutBanner').style.display='block';
      document.getElementById('lockoutBanner').textContent='Too many failed attempts. Account locked for 5 minutes.';
      showErr('loginError','');
    } else {
      showErr('loginError',`Wrong password. ${left} attempt${left!==1?'s':''} left before lockout.`);
    }
  }
}

// ── SESSION START ──
function startSession(user) {
  CURRENT_USER    = user.key;
  CURRENT_DISPLAY = user.displayName;
  const token = generateToken();
  // Update token
  const users = getAllUsers();
  const idx = users.findIndex(u=>u.key===user.key);
  if(idx>=0){ users[idx].token = token; saveAllUsers(users); }
  localStorage.setItem(SESSION_KEY, JSON.stringify({key:user.key, token, ts: Date.now()}));
  showDashboard(user.displayName);
}

// ── RESET PASSWORD ──
async function doReset() {
  const user = ACTIVE_STEP_USER;
  if(!user) return;
  const pw1 = document.getElementById('resetPw1').value;
  const pw2 = document.getElementById('resetPw2').value;
  const pin  = document.getElementById('resetPin').value;

  if(!pw1 || pw1.length < 6) return showErr('resetError','Password must be at least 6 characters');
  if(pw1 !== pw2)             return showErr('resetError','Passwords do not match');
  if(!pin)                    return showErr('resetError','Enter your PIN to verify identity');

  const pinHash = await sha256(pin + user.key);
  if(pinHash !== user.pinHash) return showErr('resetError','Wrong PIN. Cannot reset password.');

  const newPwHash = await sha256(pw1 + user.key + 'ft_salt_2026');
  const users = getAllUsers();
  const idx = users.findIndex(u=>u.key===user.key);
  if(idx>=0){ users[idx].pwHash = newPwHash; saveAllUsers(users); }
  clearLockout(user.key);
  SESSION_PW_HASH = newPwHash;
  showErr('resetError','');
  startSession({...user, pwHash:newPwHash});
}

// ── CHANGE PASSWORD (in settings) ──
async function changePassword() {
  const oldPw = document.getElementById('cpOld').value;
  const newPw1 = document.getElementById('cpNew1').value;
  const newPw2 = document.getElementById('cpNew2').value;

  if(!oldPw) return showErr('cpError','Enter your current password');
  const oldHash = await sha256(oldPw + CURRENT_USER + 'ft_salt_2026');
  const user = getUserByKey(CURRENT_USER);
  if(!user || oldHash !== user.pwHash) return showErr('cpError','Current password is incorrect');
  if(!newPw1 || newPw1.length < 6) return showErr('cpError','New password must be at least 6 characters');
  if(newPw1 !== newPw2) return showErr('cpError','New passwords do not match');

  // Re-encrypt all data with new key
  const newHash = await sha256(newPw1 + CURRENT_USER + 'ft_salt_2026');
  const [savings, spends, goal, budget] = await Promise.all([
    loadSavings(), loadSpends(), loadGoal(), loadBudget()
  ]);

  SESSION_PW_HASH = newHash;
  await Promise.all([saveSavings(savings), saveSpends(spends), saveGoal(goal), saveBudget(budget)]);

  const users = getAllUsers();
  const idx = users.findIndex(u=>u.key===CURRENT_USER);
  if(idx>=0){ users[idx].pwHash = newHash; saveAllUsers(users); }

  showErr('cpError','');
  document.getElementById('cpOld').value='';
  document.getElementById('cpNew1').value='';
  document.getElementById('cpNew2').value='';
  showToast('✅ Password updated!');
}

// ── CHANGE PIN ──
async function changePin() {
  const newPin = document.getElementById('cpPin').value;
  if(!newPin || newPin.length < 4 || !/^\d+$/.test(newPin))
    return showErr('cpPinError','PIN must be 4–6 digits');
  const pinHash = await sha256(newPin + CURRENT_USER);
  const users = getAllUsers();
  const idx = users.findIndex(u=>u.key===CURRENT_USER);
  if(idx>=0){ users[idx].pinHash = pinHash; saveAllUsers(users); }
  document.getElementById('cpPin').value='';
  showErr('cpPinError','');
  showToast('✅ PIN updated!');
}

// ── DELETE ACCOUNT ──
async function deleteAccount() {
  if(!confirm(`Permanently delete account "${CURRENT_DISPLAY}" and ALL data? This cannot be undone.`)) return;
  const pw = prompt('Enter your password to confirm deletion:');
  if(!pw) return;
  const hash = await sha256(pw + CURRENT_USER + 'ft_salt_2026');
  const user = getUserByKey(CURRENT_USER);
  if(!user || hash !== user.pwHash) { alert('Wrong password. Account not deleted.'); return; }

  // Wipe all data keys
  ['savings','spends','goal','budget'].forEach(f => localStorage.removeItem(userDataKey(f)));
  localStorage.removeItem('ft_lock_'+CURRENT_USER);
  localStorage.removeItem('ft_lock_'+CURRENT_USER+'_pin');

  // Remove from users list
  const users = getAllUsers().filter(u=>u.key!==CURRENT_USER);
  saveAllUsers(users);
  localStorage.removeItem(SESSION_KEY);

  closeSettings();
  CURRENT_USER = null; SESSION_PW_HASH = null;
  showAuthOverlay();
  showToast('Account deleted.');
}

