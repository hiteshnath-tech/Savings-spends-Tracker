    <div class="login-sub">Enter your password to continue</div>
    <div id="lockoutBanner" class="lockout-banner" style="display:none"></div>
    <div class="field" style="margin-top:4px">
      <label>Password</label>
      <div class="pw-wrap">
        <input type="password" id="loginPassword" placeholder="Your password" maxlength="64"
          onkeydown="if(event.key==='Enter')doLogin()" autocomplete="current-password"/>
        <button class="pw-eye" type="button" onclick="togglePw('loginPassword',this)">👁</button>
      </div>
    </div>
    <div class="login-error" id="loginError"></div>
    <button class="btn btn-green" style="width:100%;margin-top:12px" onclick="doLogin()">Sign In →</button>
    <div style="display:flex;gap:10px;margin-top:10px">
      <button class="btn btn-ghost" style="flex:1;font-size:12px" onclick="showStep('stepPin')">Use PIN instead</button>
      <button class="btn btn-ghost" style="flex:1;font-size:12px" onclick="showStep('stepReset')">Forgot password?</button>
