// ── WEEKLY COMPARISON ──
function showWeeklyComparison(spends) {
  const now=new Date();
  const startThisWeek=new Date(now); startThisWeek.setDate(now.getDate()-now.getDay());
  const startLastWeek=new Date(startThisWeek); startLastWeek.setDate(startLastWeek.getDate()-7);
  const endLastWeek=new Date(startThisWeek); endLastWeek.setDate(endLastWeek.getDate()-1);
  const tw=startThisWeek.toISOString().split("T")[0];
  const lw=startLastWeek.toISOString().split("T")[0];
  const el=endLastWeek.toISOString().split("T")[0];
  const thisW=spends.filter(s=>s.date>=tw).reduce((a,s)=>a+s.amount,0);
  const lastW=spends.filter(s=>s.date>=lw&&s.date<=el).reduce((a,s)=>a+s.amount,0);
  const compare=document.getElementById("weekCompare"),text=document.getElementById("weekText");
  if(lastW>0&&thisW>0) {
    const pct=Math.round((thisW-lastW)/lastW*100);
    compare.style.display="flex";
    compare.querySelector('.week-icon').textContent=pct>0?"⚠️":"✅";
    text.className="week-text"+(pct<=0?" good":"");
    text.innerHTML=pct>0?`You spent <strong>${pct}% more than last week</strong> — ₹${thisW.toLocaleString("en-IN")} vs ₹${lastW.toLocaleString("en-IN")}.`:`Great! Spent <strong>${Math.abs(pct)}% less than last week</strong> — ₹${thisW.toLocaleString("en-IN")} vs ₹${lastW.toLocaleString("en-IN")}.`;
  } else { compare.style.display="none"; }
}

// ── AI INSIGHT ──
function updateAIInsight(savings,spends) {
  const totalSaved=savings.reduce((s,e)=>s+e.amount,0);
  const totalSpent=spends.reduce((s,e)=>s+e.amount,0);
  const catTotals={};
  spends.forEach(s=>{catTotals[s.cat]=(catTotals[s.cat]||0)+s.amount;});
  const topCat=Object.entries(catTotals).sort((a,b)=>b[1]-a[1])[0];
  const avgSave=savings.length?totalSaved/savings.length:0;
  const savingRate=totalSpent>0?Math.round(totalSaved/(totalSaved+totalSpent)*100):100;
  let insight="";
  if(!totalSaved&&!totalSpent) insight="Add some savings or expenses to get personalized financial insights! 💡";
  else if(savingRate>70) insight=`🌟 Excellent savings rate of <strong>${savingRate}%</strong>! Strong financial habits. At ₹${Math.round(avgSave)}/day average, you're on track for big goals.`;
  else if(savingRate>40) insight=`You're saving <strong>${savingRate}%</strong> of your money flow. ${topCat?`Top spend: <strong>${topCat[0]}</strong> at ₹${topCat[1].toLocaleString("en-IN")}`:""}. Trim it for bigger savings.`;
  else insight=`⚠️ Only <strong>${savingRate}%</strong> saving rate. ${topCat?`<strong>${topCat[0]}</strong> is your top category at ₹${topCat[1].toLocaleString("en-IN")}`:""}. Try 50/30/20 rule.`;
  document.getElementById("aiText").innerHTML=insight;
}

