    <div class="login-error" id="pinError"></div>
    <button class="btn btn-ghost" style="width:100%;margin-top:8px;font-size:12px" onclick="showStep('stepLogin')">Use Password instead</button>
  </div>

  <!-- ── STEP 4: RESET PASSWORD ── -->
