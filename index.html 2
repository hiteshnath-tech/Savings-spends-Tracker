// ── SESSION RESTORE ──
async function restoreSession() {
  try {
    const s = JSON.parse(localStorage.getItem(SESSION_KEY)||'null');
    if(!s) return false;
    // Session expires after 24h
    if(Date.now() - s.ts > 24*60*60*1000) { localStorage.removeItem(SESSION_KEY); return false; }
    const user = getUserByKey(s.key);
    if(!user || user.token !== s.token) return false;
    CURRENT_USER    = user.key;
    CURRENT_DISPLAY = user.displayName;
    SESSION_PW_HASH = user.pwHash;
    ACTIVE_STEP_USER = user;
    return user;
  } catch(e){ return false; }
}

