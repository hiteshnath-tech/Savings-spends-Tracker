/* EXPORT ROW */
.export-row {
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
  margin-bottom: 12px;
}

.export-btn {
  flex: 1;
  min-width: 100px;
  padding: 10px 14px;
  background: var(--glass);
  border: 1px solid var(--glass-border);
  border-radius: 10px;
  font-family: 'Syne', sans-serif;
  font-size: 12px;
  font-weight: 700;
  color: var(--text2);
  cursor: pointer;
  transition: all 0.2s;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
}

.export-btn:hover { color: var(--text); background: rgba(255,255,255,0.08); border-color: var(--neon); }

/* BOTTOM NAV (MOBILE) */
.bottom-nav {
  display: none;
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 300;
  background: rgba(10,13,20,0.9);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-top: 1px solid var(--glass-border);
  padding: 8px 16px 20px;
}

[data-theme="light"] .bottom-nav { background: rgba(240,242,248,0.9); }

.bottom-nav-inner {
  display: flex;
  justify-content: space-around;
}

.nav-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 3px;
  padding: 6px 14px;
  border-radius: 12px;
  cursor: pointer;
  transition: all 0.2s;
  border: none;
  background: transparent;
  font-family: 'Syne', sans-serif;
}

.nav-item:hover { background: rgba(255,255,255,0.05); }
.nav-item.active { background: rgba(0,245,160,0.1); }

.nav-icon { font-size: 20px; }
.nav-label { font-size: 9px; font-weight: 700; color: var(--text3); text-transform: uppercase; letter-spacing: 0.5px; transition: color 0.2s; }
.nav-item.active .nav-label { color: var(--neon); }

@media (max-width: 600px) {
  .bottom-nav { display: block; }
  .tabs { display: none; }
  .wrap { padding-bottom: 110px; }
}

/* AI SUGGESTION */
.ai-bubble {
  background: linear-gradient(135deg, rgba(167,139,250,0.1), rgba(0,212,255,0.08));
  border: 1px solid rgba(167,139,250,0.25);
  border-radius: var(--radius);
